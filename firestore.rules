rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Is user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Is user accessing their own data?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS
    match /users/{userId} {
      allow read: if true; // Public profiles (guest read)
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false; // Soft deletes preferred
    }

    // POSTS
    match /posts/{postId} {
      allow read: if true; // Public feed (guest read)
      allow create: if isAuthenticated();
      // Only author can edit/delete
      allow update, delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }

    // COMMENTS (Subcollection of posts or separate, assuming separate for ease)
    match /comments/{commentId} {
      allow read: if true; // Public comments (guest read)
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && isOwner(resource.data.authorId);
    }
    
    // MESSAGES
    match /messages/{messageId} {
      // Must be sender or receiver
      allow read: if isAuthenticated() && 
                 (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.senderId);
      // No edit/delete for messages typically in chat apps, or just sender
      allow update, delete: if false; 
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      // Only recipient can read/update their notifications
      allow read, update: if isAuthenticated() && isOwner(resource.data.recipientId);
      // System or triggered by other users (e.g. liking creates notif)
      allow create: if isAuthenticated(); 
      allow delete: if isAuthenticated() && isOwner(resource.data.recipientId);
    }

    // FOLLOWERS
    // E.g., /followers/{userId}/userFollowers/{followerId}
    match /followers/{userId}/userFollowers/{followerId} {
      // Public follow lists
      allow read: if true; 
      // User can only make themselves follow someone else
      allow write: if isAuthenticated() && request.auth.uid == followerId;
    }
  }
}
